// Alquiler Karaoke — esquema Prisma
// Fase 1 (Bloque 2): modelo mínimo. Packs, tarifas, reservas, etc. llegan en sus fases.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Roles del sistema (DECISIONS.md) ─────────────────────────────
enum Role {
  SUPERADMIN
  ADMIN
  COMERCIAL
  TECNICO
  COLABORADOR
  CONTABILIDAD
  SEO_CONTENIDOS
  ALMACEN
}

// Estado de una solicitud de contacto (lead).
enum ContactStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  ARCHIVED
}

// Tipo de modificador de precio: cantidad fija (céntimos) o porcentaje.
enum PriceModifierType {
  FIXED
  PERCENT
}

// Estado de una reserva/solicitud de contratación.
enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

// Estado de publicación de una entrada del blog.
enum PostStatus {
  DRAFT
  PUBLISHED
}

// Estado de un contrato.
enum ContractStatus {
  DRAFT // generado, aún no enviado
  SENT // enviado al cliente (link disponible)
  SIGNED // firmado por el cliente
  CANCELLED
}

// Método de pago de un cobro manual (CARD reservado para Stripe en Fase 4).
enum PaymentMethod {
  TRANSFER
  BIZUM
  CASH
  CARD
  OTHER
}

// Estado de pago de una reserva (derivado de la suma de cobros).
enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

// Tipos de suplemento configurables (DECISIONS.md / docs 08).
enum SurchargeType {
  WEEKEND
  NIGHT
  SPECIAL_DATE
  HIGH_DEMAND
  EXTERIOR
  DIFFICULT_SETUP
  EVENT_TYPE
  OTHER
}

// ── Usuarios y autenticación (compatible Auth.js / NextAuth) ─────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // Hash de contraseña para login con credenciales (Bloque 3).
  passwordHash  String?
  // Un usuario puede tener varios roles.
  roles         Role[]    @default([])
  isActive      Boolean   @default(true)

  accounts         Account[]
  sessions         Session[]
  auditLogs        AuditLog[]
  contactResponses ContactRequest[]
  handledBookings  Booking[]
  payments         Payment[]
  contracts        Contract[]
  posts            Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Registro de auditoría (regla: admin con logs) ────────────────
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // p.ej. "user.login", "config.update"
  entity    String? // p.ej. "SiteConfig"
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ── Configuración de empresa y branding (configurable desde admin) ─
// Patrón singleton: una sola fila con id = "default".
model SiteConfig {
  id           String  @id @default("default")
  companyName  String  @default("Alquiler Karaoke")
  legalName    String?
  taxId        String? // CIF/NIF
  email        String?
  phone        String  @default("607724965")
  whatsapp     String?
  address      String?
  // Branding
  logoUrl      String?
  faviconUrl   String?
  ogImageUrl   String?
  primaryColor String? @default("#22d3ee")
  // Redes sociales (URLs)
  instagram    String?
  facebook     String?
  tiktok       String?
  youtube      String?
  twitter      String?
  // Datos de pago para el cliente (transferencia / Bizum)
  iban         String?
  bizum        String?
  paymentInfo  String? // instrucciones libres mostradas al cliente
  // Cláusulas por defecto para los contratos (snapshot al generar cada contrato)
  contractTerms String?
  // Campos extra flexibles (redes, horarios, etc.) sin tocar el esquema.
  extra        Json?

  updatedAt DateTime @updatedAt
}

// ── Solicitudes de contacto (leads desde la web pública) ─────────
model ContactRequest {
  id      String        @id @default(cuid())
  name    String
  email   String
  phone   String?
  city    String?
  message String
  locale  String?
  status  ContactStatus @default(NEW)

  // Consentimiento RGPD
  acceptedTerms    Boolean   @default(false)
  marketingConsent Boolean   @default(false)
  consentVersion   String?
  consentAt        DateTime?

  // Respuesta del admin
  response      String?
  respondedById String?
  respondedAt   DateTime?
  respondedBy   User?     @relation(fields: [respondedById], references: [id], onDelete: SetNull)

  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ── Packs, precios y tarifas (Fase 3) ────────────────────────────
// Precios SIEMPRE en céntimos (Int), SIN IVA. Se muestran como "desde X € + IVA".
model Pack {
  id               String  @id @default(cuid())
  slug             String  @unique
  name             String
  shortDescription String?
  description      String?
  category         String? // p. ej. "Karaoke", "Gaming / Consolas", "Fiesta Holi"
  imageUrl         String? // foto del producto (si vacío, se usa un placeholder por categoría)
  imageAlt         String? // texto alternativo de la foto (SEO/accesibilidad)
  basePrice        Int // céntimos, sin IVA (precio base, 4 h salvo isPerDay)
  includedHours    Int     @default(4)
  extraHourPrice   Int     @default(0) // céntimos por hora extra
  isPerDay         Boolean @default(false) // OkeBox: precio por día completo

  // Reserva (pago para reservar)
  depositType  PriceModifierType @default(PERCENT)
  depositValue Int               @default(30) // % o céntimos según depositType

  // Fianza (céntimos)
  securityDeposit Int @default(0)

  // Traducciones por locale: { "en": { name, shortDescription, description }, "fr": {...} }
  translations Json?

  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([isActive, sortOrder])
}

model Extra {
  id           String  @id @default(cuid())
  slug         String  @unique
  name         String
  description  String?
  category     String?
  price        Int // céntimos, sin IVA
  // Categorías de pack a las que aplica este extra. Vacío = aplica a todos.
  appliesToCategories String[] @default([])
  translations Json?
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)
}

// Zona tarifaria: suplemento por desplazamiento/cobertura (céntimos, sin IVA).
model TariffZone {
  id            String     @id @default(cuid())
  name          String     @unique
  supplement    Int        @default(0) // céntimos
  pendingConfig Boolean    @default(false) // zona sin suplemento definido aún
  isActive      Boolean    @default(true)
  sortOrder     Int        @default(0)
  provinces     Province[]
}

// Provincia normalizada, asignada a una zona tarifaria.
model Province {
  id       String      @id @default(cuid())
  name     String      @unique
  slug     String      @unique
  zoneId   String?
  zone     TariffZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  isActive Boolean     @default(true)

  @@index([zoneId])
}

model Surcharge {
  id        String            @id @default(cuid())
  name      String
  type      SurchargeType
  valueType PriceModifierType @default(PERCENT)
  value     Int // % o céntimos según valueType
  isActive  Boolean           @default(true)
  config    Json? // condiciones flexibles (días, rango de fechas, etc.)
}

// Códigos de descuento promocionales (aplicados al solicitar presupuesto).
model DiscountCode {
  id         String            @id @default(cuid())
  code       String            @unique // se guarda en MAYÚSCULAS
  valueType  PriceModifierType @default(PERCENT)
  value      Int // % o céntimos según valueType
  isActive   Boolean           @default(true)
  maxUses    Int? // null = ilimitado
  usedCount  Int               @default(0)
  validFrom  DateTime?
  validUntil DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([isActive])
}

// Configuración global de precios (singleton: id = "default").
model PricingConfig {
  id         String   @id @default("default")
  vatPercent Int      @default(21)
  currency   String   @default("EUR")
  updatedAt  DateTime @updatedAt
}

// ── Reservas / solicitudes de contratación (Fase 3 Bloque 5) ─────
// Toda contratación nace PENDING (pendiente de validación por admin).
model Booking {
  id String @id @default(cuid())

  // Selección (con snapshot de nombre por si el pack cambia/borra)
  packId    String?
  pack      Pack?    @relation(fields: [packId], references: [id], onDelete: SetNull)
  packName  String
  hours     Int      @default(4)
  province  String?
  eventDate DateTime?
  eventTime String? // hora de inicio aproximada (texto, p. ej. "20:00")
  attendees Int? // nº de asistentes previstos
  night     Boolean  @default(false)
  extras    Json? // snapshot: [{ name, price }]
  // Actividades del presupuesto (primera + adicionales). Snapshot:
  // [{ packName, hours, extras: [{name,price}], lineTotal }] (lineTotal en céntimos, sin IVA/suplementos).
  activities Json?

  // Importe (snapshot en céntimos, sin/with IVA según campo)
  subtotal        Int @default(0)
  discount        Int @default(0) // descuento total aplicado (profesional + código), céntimos
  discountCode    String? // código promocional usado (snapshot)
  vat             Int @default(0)
  total           Int @default(0)
  deposit         Int @default(0)
  securityDeposit Int @default(0)

  // Pagos (cobros manuales registrados por el admin)
  paymentStatus PaymentStatus @default(PENDING)
  amountPaid    Int           @default(0) // céntimos cobrados (caché de la suma de Payment)
  payments      Payment[]
  contract      Contract?

  // Cliente
  name       String
  email      String
  phone      String?
  message    String?
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Consentimiento RGPD
  acceptedTerms    Boolean   @default(false)
  marketingConsent Boolean   @default(false)
  consentVersion   String?
  consentAt        DateTime?

  // Gestión
  status      BookingStatus @default(PENDING)
  adminNote   String?
  handledById String?
  handledBy   User?         @relation(fields: [handledById], references: [id], onDelete: SetNull)
  handledAt   DateTime?

  locale    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([eventDate])
  @@index([paymentStatus])
}

// ── Pagos (cobros manuales: transferencia, Bizum, efectivo…) ─────
model Payment {
  id          String        @id @default(cuid())
  bookingId   String
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount      Int // céntimos (positivo = cobro, negativo = reembolso)
  method      PaymentMethod @default(TRANSFER)
  reference   String? // nº de operación / concepto
  note        String?
  paidAt      DateTime      @default(now())
  createdById String?
  createdBy   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())

  @@index([bookingId])
}

// ── Contratos (generación PDF + firma web) ───────────────────────
model Contract {
  id          String         @id @default(cuid())
  bookingId   String         @unique
  booking     Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  number      String         @unique // CON-2026-XXXXXX
  status      ContractStatus @default(DRAFT)
  terms       String // snapshot de las cláusulas en el momento de generar
  token       String         @unique // secreto del enlace público de firma
  contentHash String? // sha256 del contenido firmado (integridad)

  // Firma del cliente
  signedName      String?
  signedAt        DateTime?
  signerIp        String?
  signerUserAgent String?
  signatureImage  String? // PNG dataURL de la firma dibujada (opcional)

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

// ── Bloqueos de fecha (disponibilidad) ──────────────────────────
model DateBlock {
  id        String    @id @default(cuid())
  date      DateTime // día bloqueado
  endDate   DateTime? // para rango (opcional)
  reason    String?
  createdAt DateTime  @default(now())

  @@index([date])
}

// ── Marcas colaboradoras (logo, enlace y descripción) ───────────
model Collaborator {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  url         String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// Estado de un trabajo de importación de canciones.
enum ImportStatus {
  PENDING
  RUNNING
  DONE
  ERROR
}

// ── Catálogo de canciones (Fase 6) ──────────────────────────────
// Trabajo de importación (subida del Excel/CSV desde el admin, procesado en
// segundo plano por lotes). El admin consulta el progreso por su estado.
model SongImportJob {
  id          String       @id @default(cuid())
  filename    String
  format      String // "xlsx" | "csv"
  status      ImportStatus @default(PENDING)
  processed   Int          @default(0) // filas leídas
  imported    Int          @default(0) // canciones insertadas
  uniqueCount Int          @default(0) // no repetidas tras optimizar
  message     String?
  createdById String?
  createdAt   DateTime     @default(now())
  finishedAt  DateTime?

  @@index([createdAt])
}

// Marca/proveedor de la canción. "quality" decide qué versión se muestra
// cuando un mismo Título+Intérprete aparece en varias marcas (mayor = mejor).
model SongBrand {
  id       String  @id @default(cuid())
  name     String  @unique
  quality  Int     @default(0)
  isActive Boolean @default(true)
  songs    Song[]
}

// Canción del catálogo. Se importan todas; "isPrimary" marca la versión visible
// tras la optimización (deduplicación por dedupKey según la calidad de la marca).
model Song {
  id           String     @id @default(cuid())
  languageCode String // abreviatura del Excel (AL, IN, ES…)
  code         String? // código interno del Excel
  title        String
  performer    String
  brandId      String?
  brand        SongBrand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  dedupKey     String // normalizado: title|performer (agrupa duplicados)
  isPrimary    Boolean    @default(true) // versión visible tras optimizar
  createdAt    DateTime   @default(now())

  @@index([languageCode, isPrimary])
  @@index([dedupKey])
  @@index([isPrimary])
}

// ── Ciudades (landings SEO locales, gestionables desde el admin) ──
model City {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  province  String
  region    String // comunidad autónoma (agrupa el hub)
  nearby    String[] // poblaciones cercanas que cubrimos (contenido local)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ── Servicios (páginas SEO por servicio, con packs asociados) ────
model Service {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  category         String? // categoría de Pack asociada (lista esos packs)
  shortDescription String?
  description      String? // Markdown (subconjunto seguro)
  heroImageUrl     String?
  metaTitle        String?
  metaDescription  String?
  translations     Json? // { en: {name, shortDescription, description}, fr: {...} }
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ── Blog / contenidos SEO ────────────────────────────────────────
model Post {
  id              String     @id @default(cuid())
  slug            String     @unique
  locale          String     @default("es")
  title           String
  excerpt         String?
  content         String // Markdown (subconjunto seguro)
  coverImageUrl   String?
  status          PostStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  authorId        String?
  author          User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, locale, publishedAt])
}

// ── Clientes (con descuento para profesionales) ─────────────────
model Customer {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  phone           String?
  isProfessional  Boolean   @default(false)
  discountPercent Int       @default(0) // 0–35; solo se aplica si isProfessional
  notes           String?
  bookings        Booking[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isProfessional])
}
