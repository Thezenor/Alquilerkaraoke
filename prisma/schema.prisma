// Alquiler Karaoke — esquema Prisma
// Fase 1 (Bloque 2): modelo mínimo. Packs, tarifas, reservas, etc. llegan en sus fases.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Roles del sistema (DECISIONS.md) ─────────────────────────────
enum Role {
  SUPERADMIN
  ADMIN
  COMERCIAL
  TECNICO
  COLABORADOR
  CONTABILIDAD
  SEO_CONTENIDOS
  ALMACEN
}

// Estado de una solicitud de contacto (lead).
enum ContactStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  ARCHIVED
}

// Tipo de modificador de precio: cantidad fija (céntimos) o porcentaje.
enum PriceModifierType {
  FIXED
  PERCENT
}

// Tipos de suplemento configurables (DECISIONS.md / docs 08).
enum SurchargeType {
  WEEKEND
  NIGHT
  SPECIAL_DATE
  HIGH_DEMAND
  EXTERIOR
  DIFFICULT_SETUP
  EVENT_TYPE
  OTHER
}

// ── Usuarios y autenticación (compatible Auth.js / NextAuth) ─────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // Hash de contraseña para login con credenciales (Bloque 3).
  passwordHash  String?
  // Un usuario puede tener varios roles.
  roles         Role[]    @default([])
  isActive      Boolean   @default(true)

  accounts         Account[]
  sessions         Session[]
  auditLogs        AuditLog[]
  contactResponses ContactRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Registro de auditoría (regla: admin con logs) ────────────────
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // p.ej. "user.login", "config.update"
  entity    String? // p.ej. "SiteConfig"
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ── Configuración de empresa y branding (configurable desde admin) ─
// Patrón singleton: una sola fila con id = "default".
model SiteConfig {
  id           String  @id @default("default")
  companyName  String  @default("Alquiler Karaoke")
  legalName    String?
  taxId        String? // CIF/NIF
  email        String?
  phone        String  @default("607724965")
  whatsapp     String?
  address      String?
  // Branding
  logoUrl      String?
  faviconUrl   String?
  ogImageUrl   String?
  primaryColor String? @default("#22d3ee")
  // Campos extra flexibles (redes, horarios, etc.) sin tocar el esquema.
  extra        Json?

  updatedAt DateTime @updatedAt
}

// ── Solicitudes de contacto (leads desde la web pública) ─────────
model ContactRequest {
  id      String        @id @default(cuid())
  name    String
  email   String
  phone   String?
  city    String?
  message String
  locale  String?
  status  ContactStatus @default(NEW)

  // Respuesta del admin
  response      String?
  respondedById String?
  respondedAt   DateTime?
  respondedBy   User?     @relation(fields: [respondedById], references: [id], onDelete: SetNull)

  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ── Packs, precios y tarifas (Fase 3) ────────────────────────────
// Precios SIEMPRE en céntimos (Int), SIN IVA. Se muestran como "desde X € + IVA".
model Pack {
  id               String  @id @default(cuid())
  slug             String  @unique
  name             String
  shortDescription String?
  description      String?
  basePrice        Int // céntimos, sin IVA (precio base, 4 h salvo isPerDay)
  includedHours    Int     @default(4)
  extraHourPrice   Int     @default(0) // céntimos por hora extra
  isPerDay         Boolean @default(false) // OkeBox: precio por día completo

  // Reserva (pago para reservar)
  depositType  PriceModifierType @default(PERCENT)
  depositValue Int               @default(30) // % o céntimos según depositType

  // Fianza (céntimos)
  securityDeposit Int @default(0)

  // Traducciones por locale: { "en": { name, shortDescription, description }, "fr": {...} }
  translations Json?

  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Extra {
  id           String  @id @default(cuid())
  slug         String  @unique
  name         String
  description  String?
  price        Int // céntimos, sin IVA
  translations Json?
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)
}

model ProvinceSupplement {
  id       String  @id @default(cuid())
  province String  @unique
  amount   Int     @default(0) // suplemento fijo en céntimos, sin IVA
  isActive Boolean @default(true)
}

model Surcharge {
  id        String            @id @default(cuid())
  name      String
  type      SurchargeType
  valueType PriceModifierType @default(PERCENT)
  value     Int // % o céntimos según valueType
  isActive  Boolean           @default(true)
  config    Json? // condiciones flexibles (días, rango de fechas, etc.)
}

// Configuración global de precios (singleton: id = "default").
model PricingConfig {
  id         String   @id @default("default")
  vatPercent Int      @default(21)
  currency   String   @default("EUR")
  updatedAt  DateTime @updatedAt
}
