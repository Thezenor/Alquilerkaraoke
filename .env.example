# ─────────────────────────────────────────────────────────────
# Alquiler Karaoke — variables de entorno (PLANTILLA)
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas el archivo `.env` real al repositorio ni expongas claves.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base de datos (PostgreSQL / Railway) — Bloque 2
DATABASE_URL=postgresql://user:password@localhost:5432/alquilerkaraoke?schema=public

# Seed: credenciales iniciales del Superadmin (cámbialas)
SUPERADMIN_EMAIL=admin@alquilerkaraoke.com
SUPERADMIN_PASSWORD=

# Autenticación (NextAuth / Auth.js) — Bloque 3
# Genera el secreto con: npx auth secret  (o openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Pagos (Stripe) — Fase 4
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (elige uno) — Fases posteriores
RESEND_API_KEY=
BREVO_API_KEY=
EMAIL_FROM="Alquiler Karaoke <no-reply@alquilerkaraoke.com>"

# Storage de ficheros (S3 / Cloudflare R2) — previsto desde Fase 1
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# IA (claves también gestionables desde admin) — Fase 8
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
